# Throwaway spikes — contain real, non-committable contract paths/names
spikes/

# Backups
*.bak

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store

# Env / secrets
.env
.env.*
!.env.example

# Database: DATA stays local — never in the public repo. Each install runs its
# own Postgres; only db/schema.sql (DDL skeleton) + a generic db/seed.sql are
# tracked. No rows, dumps, or real client/deal/contract data ever leave a machine.
*.dump
*.sqlite
*.sqlite3
*.db
*.sql.gz
db/*_local.sql
db/dump*.sql
/pgdata/
/data/

# Local Claude Code settings (machine-specific perms)
.claude/settings.local.json

# Dev/throwaway artifacts (screenshots, browser tool output, sample docs)
# committed README/docs images are the exception to *.png
*.png
!docs/assets/
!docs/assets/*.png
.playwright-mcp/
sample-contract.docx
# Local-only Mode B test fixtures — real-deal-derived counterparty revisions, never commit
test-fixtures/

# Node / Next.js
node_modules/
.next/
frontend/.env*.local
.claude/settings.json

# Local sample/example contracts — never commit contract content to the public repo (privacy)
examples/
*.bak*
