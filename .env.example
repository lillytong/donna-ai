# donna.ai environment — copy to .env and fill in. Never commit .env.

# --- Database (local Postgres + pgvector via docker-compose) ---
DATABASE_URL=postgresql://donna:donna@localhost:5432/donna

# --- Anthropic API (Donna's intelligence) ---
# Local app, remote model: the app runs on your machine and calls Claude over
# HTTPS. Requires outbound internet + this key (DD-53: single-operator local).
ANTHROPIC_API_KEY=

# --- Model assignments by consequence tier (DD-35) ---
# Never hardcoded in app code; swapping a model = changing one value here.
DONNA_MODEL_HIGH=claude-opus-4-8
DONNA_MODEL_MEDIUM=claude-sonnet-4-6
DONNA_MODEL_LOW=claude-haiku-4-5-20251001

# --- Redline / export author (F25, DD-44) ---
# The operator's organization name. Authors every tracked change; never "Donna".
DONNA_REDLINE_AUTHOR=

# --- App ---
LOG_LEVEL=INFO
